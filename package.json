    "cap:open:android": "cap open android"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^1.5.0",
    "@capacitor/cli": "^5.7.0",
    "@capacitor/core": "^5.7.0",
    "@capacitor/android": "^5.7.0"
  }
}
